{
  "dashboardMetadata": {
    "name": "VaultPlane Gateway",
    "shared": false,
    "owner": "",
    "tags": ["vaultplane", "ai-gateway"],
    "preset": false
  },
  "tiles": [
    {
      "name": "Request rate by model",
      "tileType": "DATA_EXPLORER",
      "configured": true,
      "bounds": { "top": 0, "left": 0, "width": 608, "height": 304 },
      "tileFilter": {},
      "customName": "Request rate by model",
      "queries": [
        {
          "id": "A",
          "metricSelector": "vaultplane_requests_total:splitBy(\"model\"):rate",
          "enabled": true
        }
      ],
      "visualConfig": {
        "type": "GRAPH_CHART",
        "global": {},
        "rules": [
          { "matcher": "A:", "properties": { "seriesType": "LINE" }, "seriesOverrides": [] }
        ],
        "axes": { "xAxis": { "visible": true }, "yAxes": [] },
        "thresholds": []
      }
    },
    {
